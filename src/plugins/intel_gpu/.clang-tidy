---
# Intel GPU plugin clang-tidy configuration.
#
# Bootstrap of the GPU clang-tidy rollout. Policy: one PR enables exactly one
# new diagnostic. This first PR enables only modernize-use-override.
# Do not add further checks in this PR.

Checks: >
  -*,
  modernize-use-override
# Treat warnings as errors so the check is enforced during the build.
WarningsAsErrors: "modernize-use-override"
# Use clang-format for applied fixes.
FormatStyle: file
HeaderFilterRegex: ".*(src/plugins/intel_gpu|src/tests/functional/plugin/gpu)/.*"
CheckOptions:
  - key: modernize-use-override.AllowOverrideAndFinal
    value: true
---
