ir_version: 9
producer_name: "OpenVINO ONNX Frontend"
graph {
  node {
    input: "x"
    input: "scale"
    input: "zero_point"
    output: "y_q"
    name: "QuantizeLinear"
    op_type: "QuantizeLinear"
  }
  node {
    input: "y_q"
    input: "scale"
    output: "y"
    name: "DequantizeLinear"
    op_type: "DequantizeLinear"
  }
  name: "test_graph"
  initializer {
    dims: 1
    data_type: 19
    name: "zero_point"
    raw_data: "\000"
  }
  input {
    name: "x"
    type {
      tensor_type {
        elem_type: 1
        shape {
          dim { dim_value: 5 }
        }
      }
    }
  }
  input {
    name: "scale"
    type {
      tensor_type {
        elem_type: 1
        shape {
          dim { dim_value: 1 }
        }
      }
    }
  }
  input {
    name: "zero_point"
    type {
      tensor_type {
        elem_type: 19
        shape {
          dim { dim_value: 1 }
        }
      }
    }
  }
  output {
    name: "y"
    type {
      tensor_type {
        elem_type: 1
        shape {
          dim {}
        }
      }
    }
  }
}
opset_import {
  version: 19
}
