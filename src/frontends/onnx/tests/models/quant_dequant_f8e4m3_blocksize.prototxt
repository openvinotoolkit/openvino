ir_version: 10
producer_name: "OpenVINO ONNX Frontend"
graph {
  node {
    input: "x"
    input: "scale"
    input: "zero_point"
    output: "y_q"
    name: "QuantizeLinear"
    op_type: "QuantizeLinear"
    attribute {
      name: "axis"
      i: 1
      type: INT
    }
    attribute {
      name: "block_size"
      i: 2
      type: INT
    }
  }
  node {
    input: "y_q"
    input: "scale"
    input: "zero_point"
    output: "y"
    name: "DequantizeLinear"
    op_type: "DequantizeLinear"
    attribute {
      name: "axis"
      i: 1
      type: INT
    }
    attribute {
      name: "block_size"
      i: 2
      type: INT
    }
  }
  name: "test_graph"
  initializer {
    dims: 2
    dims: 2
    data_type: 17
    name: "zero_point"
    raw_data: "\000\000\000\000"
  }
  input {
    name: "x"
    type {
      tensor_type {
        elem_type: 1
        shape {
          dim { dim_value: 2 }
          dim { dim_value: 4 }
        }
      }
    }
  }
  input {
    name: "scale"
    type {
      tensor_type {
        elem_type: 1
        shape {
          dim { dim_value: 2 }
          dim { dim_value: 2 }
        }
      }
    }
  }
  input {
    name: "zero_point"
    type {
      tensor_type {
        elem_type: 17
        shape {
          dim { dim_value: 2 }
          dim { dim_value: 2 }
        }
      }
    }
  }
  output {
    name: "y"
    type {
      tensor_type {
        elem_type: 1
        shape {
          dim { dim_value: 2 }
          dim { dim_value: 4 }
        }
      }
    }
  }
}
opset_import {
  version: 21
}
